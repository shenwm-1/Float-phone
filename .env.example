# 自部署默认推荐开启：跳过作者官方账号/激活码系统，使用本地单机账号。
# 作者自己的 Netlify 链接版不要设置这个变量。
NEXT_PUBLIC_SELF_HOSTED_MODE=true

# 可选：如果你要启用自己的 Supabase 云端功能，请填写自己的项目，不要使用作者的项目。
# 需要先在 Supabase SQL Editor 执行 docs/*.sql 中对应功能的建表脚本。
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 可选：账号门禁签名密钥。启用账号系统时建议设置为随机长字符串。
ACCOUNT_GATE_SECRET=

# 可选：成年审核/激活码后台管理密钥。
VERIFY_ADMIN_KEY=

# 可选：应用市场审核后台密钥。不填时会回退使用 VERIFY_ADMIN_KEY。
APP_MARKET_ADMIN_KEY=

# 可选：启用便签墙实时刷新才需要。注意 NEXT_PUBLIC_* 会公开到浏览器，不要放 service_role。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 可选：第三方能力。
TRIPO_API_KEY=
IMGBB_API_KEY=
WEIXIN_PROXY=
NEXT_PUBLIC_IMAGE_GEN_PROXY_URL=
# 可选：网易云音乐 API（NeteaseCloudMusicApi 兼容实例）。留空时在线音乐功能隐藏，
# 用户也可在音乐 APP 设置里自行填写。请部署你自己的实例，不要使用他人的。
NEXT_PUBLIC_DEFAULT_NETEASE_API_BASE=
# 可选：历史默认 API 地址（逗号分隔）。老用户浏览器里存的旧默认地址会自动迁移到当前默认。
NEXT_PUBLIC_LEGACY_NETEASE_API_BASES=
NEXT_PUBLIC_NETEASE_REAL_IP=
